{
  "name": "@one710/recollect",
  "version": "1.7.0",
  "description": "Auto-summarizing memory layer for AI agents using Node.js native SQLite.",
  "license": "MIT",
  "author": "one710",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/one710/recollect.git"
  },
  "bugs": {
    "url": "https://github.com/one710/recollect/issues"
  },
  "homepage": "https://github.com/one710/recollect#readme",
  "keywords": [
    "ai",
    "memory",
    "summarization",
    "sqlite",
    "postgres",
    "postgresql",
    "supabase",
    "postgrest",
    "history"
  ],
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:pg": "NODE_OPTIONS=--experimental-vm-modules RECOLLECT_TEST_PG_URL=postgresql://recollect:recollect@localhost:5432/recollect jest",
    "test:supabase": "NODE_OPTIONS=--experimental-vm-modules RECOLLECT_TEST_SUPABASE_URL=http://127.0.0.1:35432 RECOLLECT_TEST_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0 jest",
    "test:docker": "NODE_OPTIONS=--experimental-vm-modules RECOLLECT_TEST_PG_URL=postgresql://recollect:recollect@localhost:5432/recollect RECOLLECT_TEST_SUPABASE_URL=http://127.0.0.1:35432 RECOLLECT_TEST_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0 jest"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.20.0",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "pg": "^8.20.0",
    "sqlite3": "^5.1.7",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "pg": "^8.11.0",
    "sqlite3": "^5.1.7"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "sqlite3": {
      "optional": true
    }
  },
  "dependencies": {
    "js-jsonl": "^1.1.1"
  }
