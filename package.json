{
  "name": "@one710/recollect",
  "version": "1.6.0",
  "description": "Auto-summarizing memory layer for AI agents using Node.js native SQLite.",
  "license": "MIT",
  "author": "one710",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/one710/recollect.git"
  },
  "bugs": {
    "url": "https://github.com/one710/recollect/issues"
  },
  "homepage": "https://github.com/one710/recollect#readme",
  "keywords": [
    "ai",
    "memory",
    "summarization",
    "sqlite",
    "postgres",
    "postgresql",
    "history"
  ],
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:pg": "NODE_OPTIONS=--experimental-vm-modules RECOLLECT_TEST_PG_URL=postgresql://recollect:recollect@localhost:5432/recollect jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.20.0",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "pg": "^8.20.0",
    "sqlite3": "^5.1.7",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "pg": "^8.11.0",
    "sqlite3": "^5.1.7"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "sqlite3": {
      "optional": true
    }
  },
  "dependencies": {
    "js-jsonl": "^1.1.1"
  }
}
